#!/bin/bash
# Bump patch version in plugin.json and commit the change.
# Usage: bump-version [component]  (default: patch)

set -e

PLUGIN_DIR="$(cd "$(dirname "$0")/.." && pwd)"
JSON="$PLUGIN_DIR/.claude-plugin/plugin.json"

OLD=$(grep '"version"' "$JSON" | sed 's/.*"version": *"\(.*\)".*/\1/')
MAJOR=$(echo "$OLD" | cut -d. -f1)
MINOR=$(echo "$OLD" | cut -d. -f2)
PATCH=$(echo "$OLD" | cut -d. -f3)

case "${1:-patch}" in
  major) NEW="$((MAJOR + 1)).0.0" ;;
  minor) NEW="$MAJOR.$((MINOR + 1)).0" ;;
  patch) NEW="$MAJOR.$MINOR.$((PATCH + 1))" ;;
  *) echo "Usage: bump-version [major|minor|patch]" >&2; exit 1 ;;
esac

sed -i "s/\"version\": \"$OLD\"/\"version\": \"$NEW\"/" "$JSON"
echo "bump ldz-memory v$OLD -> v$NEW"
